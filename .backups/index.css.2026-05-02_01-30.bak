@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  :root {
    /* ═══════════════════════════════════════════════════════════════
       DARK MODE — Deepened surface ramp per FIX_MANUAL Section 1
       Each level ~5% lighter than the one below for clear elevation
       ═══════════════════════════════════════════════════════════════ */
    --ink: 20 17 14;
    --ink-2: 14 12 10;
    --surface: 29 24 20;
    --card: 39 31 26;
    --card-hi: 50 40 33;
    --border: 74 68 60;
    --border-2: rgba(255, 230, 200, 0.10);

    --bright: 245 234 216;
    --bright-2: rgba(245, 234, 216, 0.72);
    --bright-3: rgba(245, 234, 216, 0.50);
    --muted: 138 122 100;
    --muted-2: rgba(138, 122, 100, 0.66);

    --accent: 232 181 74;
    --accent-2: 241 197 96;
    --accent-glow: rgba(232, 181, 74, 0.14);

    --bo: 147 218 253;
    --boro: 211 197 254;
    --sm: 134 239 200;
    --amber: 252 201 77;
    --rose: 251 138 153;

    --sans: 'Geist', system-ui, -apple-system, 'Segoe UI', sans-serif;
    --serif: 'Fraunces', Georgia, serif;
    --mono: 'JetBrains Mono', ui-monospace, monospace;

    /* Shadow system — per FIX_MANUAL Section 2 */
    --shadow-sm: 0 1px 2px rgba(0,0,0,0.4);
    --shadow-md: 0 4px 12px rgba(0,0,0,0.5), 0 1px 2px rgba(0,0,0,0.6);
    --shadow-lg: 0 16px 40px rgba(0,0,0,0.6), 0 2px 4px rgba(0,0,0,0.7);
  }

  * { -webkit-tap-highlight-color: transparent; }
  html { font-family: var(--sans); }
  body {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    background: rgb(var(--ink));
    color: rgb(var(--bright));
    transition: background-color 0.2s, color 0.2s;
    background-image:
      radial-gradient(1200px 600px at 80% -10%, rgba(232, 181, 74, 0.06), transparent 60%),
      radial-gradient(900px 500px at -10% 110%, rgba(232, 181, 74, 0.04), transparent 60%);
  }

  ::placeholder { color: rgb(var(--muted) / 0.5) !important; opacity: 0.7 !important; }
  ::-webkit-input-placeholder { color: rgb(var(--muted) / 0.5) !important; }

  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: rgb(var(--border)); border-radius: 2px; }

  /* ═══════════════════════════════════════════════════════════════
     LIGHT MODE — Layer 1: Token redefines
     ═══════════════════════════════════════════════════════════════ */
  body.light {
    --ink: 247 243 236;
    --ink-2: 237 231 220;
    --surface: 255 255 255;
    --card: 255 255 255;
    --card-hi: 249 247 242;
    --border: 225 221 213;
    --border-2: rgba(40, 30, 20, 0.10);

    --bright: 28 24 20;
    --bright-2: rgba(28, 24, 20, 0.78);
    --bright-3: rgba(28, 24, 20, 0.50);
    --muted: 122 111 96;
    --muted-2: rgba(122, 111, 96, 0.78);

    /* --accent stays gold — brand color, intentionally unchanged */

    --bo: 37 99 235;
    --boro: 99 102 241;
    --sm: 8 145 178;
    --amber: 180 83 9;
    --rose: 190 18 60;

    --accent-glow: rgba(37, 99, 235, 0.10);

    /* Shadows — real shadows, critical for light mode elevation */
    --shadow-sm: 0 1px 2px rgba(40,30,20,0.06);
    --shadow-md: 0 4px 12px rgba(40,30,20,0.08), 0 1px 2px rgba(40,30,20,0.04);
    --shadow-lg: 0 16px 40px rgba(40,30,20,0.12), 0 2px 4px rgba(40,30,20,0.06);

    background-image:
      radial-gradient(1200px 600px at 80% -10%, rgba(37, 99, 235, 0.05), transparent 60%),
      radial-gradient(900px 500px at -10% 110%, rgba(99, 102, 241, 0.04), transparent 60%);
  }
  body.light::-webkit-scrollbar-thumb { background: #cfc9bf; }

  /* ═══════════════════════════════════════════════════════════════
     LIGHT MODE — Layer 2: Per-component overrides
     ═══════════════════════════════════════════════════════════════ */

  /* Surface unification — ALL dark brown inline rgba backgrounds */
  body.light [style*="rgba(46, 42, 37"],
  body.light [style*="rgba(54, 50, 44"],
  body.light [style*="rgba(38, 35, 32"],
  body.light [style*="rgba(34, 30, 26"],
  body.light [style*="rgba(39, 31, 26"],
  body.light [style*="rgba(29, 24, 20"],
  body.light [style*="rgba(50, 40, 33"] {
    background: rgb(var(--card)) !important;
    border-color: var(--border-2) !important;
    box-shadow: var(--shadow-md);
  }

  /* Panels with tinted backgrounds — keep their tint */
  body.light [style*="rgba(110, 231, 183"] {
    background: rgba(8, 145, 178, 0.04) !important;
  }
  body.light [style*="rgba(196, 181, 253"] {
    background: rgba(99, 102, 241, 0.04) !important;
  }

  /* Dark boxShadows → lighter in light mode */
  body.light [style*="rgba(0,0,0,0.3"],
  body.light [style*="rgba(0,0,0,0.4"],
  body.light [style*="rgba(0,0,0,0.5"],
  body.light [style*="rgba(0,0,0,0.6"],
  body.light [style*="rgba(0,0,0,0.7"],
  body.light [style*="rgba(0, 0, 0, 0.3"],
  body.light [style*="rgba(0, 0, 0, 0.4"],
  body.light [style*="rgba(0, 0, 0, 0.5"],
  body.light [style*="rgba(0, 0, 0, 0.6"],
  body.light [style*="rgba(0, 0, 0, 0.7"] {
    box-shadow: var(--shadow-lg) !important;
  }

  /* Bottom nav — per FIX_MANUAL Section 4 */
  body.light nav.fixed {
    background: rgba(255, 255, 255, 0.85) !important;
    backdrop-filter: blur(20px) !important;
    border-top-color: var(--border-2) !important;
    box-shadow: 0 -4px 16px rgba(40,30,20,0.04) !important;
  }

  /* Mobile flyout panels */
  body.light [style*="rgba(46, 42, 37, 0.92"],
  body.light [style*="rgba(46, 42, 37, 0.9"] {
    background: rgba(247, 243, 236, 0.96) !important;
  }

  /* Tailwind semantic color overrides */
  body.light .text-sky-400, body.light .text-sky-300 { color: #2563eb; }
  body.light .text-emerald-400, body.light .text-emerald-300 { color: #059669; }
  body.light .text-violet-400, body.light .text-violet-300 { color: #6366f1; }
  body.light .text-amber-400, body.light .text-amber-300 { color: #b45309; }
  body.light .text-rose-400, body.light .text-rose-300 { color: #be123c; }
  body.light .text-red-400, body.light .text-red-300 { color: #dc2626; }
  body.light .text-green-400, body.light .text-green-300 { color: #16a34a; }
  body.light .text-blue-400, body.light .text-blue-300 { color: #2563eb; }
  body.light .text-purple-400, body.light .text-purple-300 { color: #7c3aed; }
  body.light .text-yellow-400 { color: #ca8a04; }
  body.light .text-cyan-400 { color: #0891b2; }
  body.light .text-pink-400 { color: #be185d; }

  /* Semantic bg overrides */
  body.light [class*="bg-sky-"][class*="\/"] { background-color: rgba(37, 99, 235, 0.1) !important; }
  body.light [class*="bg-emerald-"][class*="\/"] { background-color: rgba(5, 150, 105, 0.1) !important; }
  body.light [class*="bg-violet-"][class*="\/"] { background-color: rgba(99, 102, 241, 0.1) !important; }
  body.light [class*="bg-red-"][class*="\/"] { background-color: rgba(220, 38, 38, 0.1) !important; }
  body.light [class*="bg-green-"][class*="\/"] { background-color: rgba(22, 163, 74, 0.1) !important; }
  body.light [class*="bg-rose-"][class*="\/"] { background-color: rgba(190, 18, 60, 0.08) !important; }
  body.light [class*="bg-amber-"][class*="\/"] { background-color: rgba(180, 83, 9, 0.08) !important; }
  body.light [class*="bg-purple-"][class*="\/"] { background-color: rgba(124, 58, 237, 0.08) !important; }
  body.light [class*="bg-pink-"][class*="\/"] { background-color: rgba(219, 39, 119, 0.08) !important; }

  /* Semantic border overrides */
  body.light [class*="border-sky-"] { border-color: rgba(37, 99, 235, 0.2) !important; }
  body.light [class*="border-emerald-"] { border-color: rgba(5, 150, 105, 0.2) !important; }
  body.light [class*="border-violet-"] { border-color: rgba(99, 102, 241, 0.2) !important; }
  body.light [class*="border-amber-"] { border-color: rgba(180, 83, 9, 0.2) !important; }
  body.light [class*="border-rose-"] { border-color: rgba(190, 18, 60, 0.2) !important; }
  body.light [class*="border-red-"] { border-color: rgba(220, 38, 38, 0.2) !important; }

  /* Gray overrides */
  body.light .bg-gray-950 { background-color: rgb(var(--ink)) !important; }
  body.light .bg-gray-900 { background-color: rgb(var(--surface)) !important; }
  body.light .bg-gray-800 { background-color: rgb(var(--card-hi)) !important; }
  body.light .text-gray-400, body.light .text-gray-500, body.light .text-gray-300 { color: rgb(var(--muted)) !important; }
  body.light .text-white { color: rgb(var(--bright)) !important; }
  body.light .border-gray-700, body.light .border-gray-800 { border-color: rgb(var(--border)) !important; }

  /* White-alpha → dark-alpha in light mode */
  body.light [class*="border-white\/"] { border-color: rgba(40, 30, 20, 0.08) !important; }
  body.light [class*="bg-white\/"] { background-color: rgba(40, 30, 20, 0.04) !important; }
  body.light .bg-black\/40, body.light .bg-black\/50, body.light .bg-black\/60 {
    background-color: rgba(40, 30, 20, 0.32) !important;
  }

  /* ═══════════════════════════════════════════════════════════════
     LIGHT MODE — Layer 3: Per-page & component overrides
     (from _ref/light-mode-overrides.css checklist)
     ═══════════════════════════════════════════════════════════════ */

  /* Hover states — blue-tinted instead of brown-tinted */
  body.light button:hover,
  body.light a:hover {
    transition: all 0.12s ease;
  }

  /* Funding numbers go gold in light mode (per LIGHT_MODE.md Section 19) */
  body.light .text-bo.font-semibold,
  body.light [class*="text-bo"][class*="font-"] {
    color: rgb(var(--accent));
  }

  /* Vote pill overrides */
  body.light [class*="bg-sm/1"][class*="text-sm"][class*="border-sm"] {
    font-weight: 700;
  }
  body.light [class*="bg-rose/1"][class*="text-rose"][class*="border-rose"] {
    font-weight: 700;
  }

  /* Settings overlay light mode */
  body.light .glass-card.p-3,
  body.light div[class*="glass-card"][class*="space-y"] {
    background: rgba(255, 255, 255, 0.98);
    box-shadow: 0 24px 60px rgba(40,30,20,0.18), 0 2px 8px rgba(40,30,20,0.08);
  }

  /* Theme toggle light mode */
  body.light [class*="fixed top-"][class*="rounded-full"] {
    background: rgba(255, 255, 255, 0.85);
    border-color: var(--border-2);
  }

  /* ═══════════════════════════════════════════════════════════════
     INPUT STYLING — per FIX_MANUAL Section 3e
     ═══════════════════════════════════════════════════════════════ */
  body.light input:not([type="checkbox"]):not([type="radio"]),
  body.light textarea,
  body.light select {
    border-color: var(--border-2);
    box-shadow: inset 0 1px 2px rgba(40,30,20,0.04);
  }
  body.light input:focus,
  body.light textarea:focus,
  body.light select:focus {
    border-color: rgb(var(--accent));
    box-shadow: 0 0 0 3px rgba(232, 181, 74, 0.12);
  }
}

@layer components {
  /* ─── Glass card — with elevation per FIX_MANUAL Section 2 ─── */
  .glass-card {
    background: rgb(var(--card) / 0.8);
    backdrop-filter: blur(12px);
    border: 1px solid var(--border-2);
    border-radius: 14px;
    box-shadow: var(--shadow-sm);
    transition: border-color 0.15s, background 0.15s, box-shadow 0.15s, transform 0.12s;
  }
  .glass-card:hover {
    border-color: rgba(255, 230, 200, 0.18);
    box-shadow: var(--shadow-md);
  }
  body.light .glass-card {
    background: #ffffff;
    border-color: var(--border-2);
    box-shadow: var(--shadow-md);
  }
  body.light .glass-card:hover {
    box-shadow: var(--shadow-lg);
    border-color: rgba(40, 30, 20, 0.14);
  }

  /* ─── Glow ─── */
  .glow-accent {
    box-shadow: 0 0 20px var(--accent-glow), 0 0 60px rgba(232, 181, 74, 0.05);
  }
  body.light .glow-accent {
    box-shadow: 0 0 20px rgba(37, 99, 235, 0.08), 0 0 60px rgba(37, 99, 235, 0.03);
  }

  /* ─── Inputs ─── */
  .input-base {
    @apply w-full rounded-[10px] px-4 py-3 focus:outline-none transition-all;
    background: rgb(var(--surface));
    border: 1px solid var(--border-2);
    color: rgb(var(--bright));
    font-size: 13px;
  }
  .input-base:focus {
    border-color: rgb(var(--accent) / 0.5);
    box-shadow: 0 0 0 3px rgb(var(--accent) / 0.12);
  }
  body.light .input-base {
    background: rgb(var(--card));
    border-color: var(--border-2);
    box-shadow: inset 0 1px 2px rgba(40,30,20,0.04);
  }
  body.light .input-base:focus {
    border-color: rgb(var(--accent));
    box-shadow: 0 0 0 3px rgba(232, 181, 74, 0.12);
  }

  /* ─── Buttons — per FIX_MANUAL Section 10 ─── */
  .btn-primary {
    @apply font-bold px-6 py-3 rounded-[10px] transition-all;
    background: rgb(var(--accent));
    color: rgb(var(--ink));
  }
  .btn-primary:hover { filter: brightness(1.08); }
  .btn-primary:active { transform: translateY(1px); }
  .btn-primary:focus-visible { outline: none; box-shadow: 0 0 0 3px rgb(var(--accent) / 0.3); }
  body.light .btn-primary { color: #ffffff; }

  .btn-ghost { color: rgb(var(--muted)); @apply px-4 py-2 rounded-lg transition-colors; }
  .btn-ghost:hover { color: rgb(var(--bright)); background: rgb(var(--card) / 0.5); }
  .btn-ghost:active { transform: translateY(1px); }

  /* ─── Tags ─── */
  .tag {
    @apply text-xs font-mono px-2 py-1 rounded-md;
    background: var(--accent-glow);
    color: rgb(var(--accent));
    border: 1px solid rgb(var(--accent) / 0.2);
  }

  /* ─── V2 glass ─── */
  .v2-glass {
    background: rgba(46, 42, 37, 0.55);
    box-shadow: var(--shadow-sm);
  }
  body.light .v2-glass {
    background: #ffffff;
    box-shadow: var(--shadow-md);
  }

  /* ─── Animations ─── */
  .fade-in { animation: fadeIn 0.18s ease-out; }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .slide-up { animation: slideUp 0.22s cubic-bezier(0.16, 1, 0.3, 1); }
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(100%); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ─── Card hover stability (ALIGNMENT_BUGS.md Bug #7) ─── */
  .glass-card, [class*="-card"] { will-change: transform; }

  /* ═══════════════════════════════════════════════════════════════
     GLOBAL INTERACTIVE STATES — per FIX_MANUAL Section 10
     ═══════════════════════════════════════════════════════════════ */
  button:not(.sc-x):not(.sc-opt):focus-visible,
  a:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px rgb(var(--accent) / 0.25);
    border-radius: inherit;
  }

  /* ═══════════════════════════════════════════════════════════════
     SCAN CHOOSER MODAL
     ═══════════════════════════════════════════════════════════════ */
  .sc-bg {
    position: fixed; inset: 0;
    z-index: 900;
    background: rgba(10, 8, 6, 0.72);
    backdrop-filter: blur(8px);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-bottom: 80px;
    animation: fadeIn .14s ease;
  }
  body.light .sc-bg { background: rgba(40, 30, 20, 0.32); }

  .sc-anchor {
    width: 760px;
    max-width: calc(100% - 40px);
    margin: 0 auto;
    animation: slideUp .22s cubic-bezier(0.2, 0.9, 0.3, 1.05);
  }

  .sc-card {
    background: rgb(var(--card));
    border: 1px solid rgba(255, 230, 200, 0.18);
    border-radius: 20px;
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }
  body.light .sc-card {
    border-color: var(--border-2);
    box-shadow: 0 24px 60px rgba(40,30,20,0.18);
  }

  .sc-head { display: flex; padding: 18px 22px 14px; border-bottom: 1px solid var(--border-2); }
  .sc-head-l { flex: 1; }
  .sc-head-h { font-family: var(--serif); font-size: 18px; font-weight: 600; color: rgb(var(--bright)); letter-spacing: -0.012em; }
  .sc-head-s { font-size: 12px; color: var(--muted-2); margin-top: 4px; }
  .sc-x {
    background: transparent;
    border: 0;
    color: rgb(var(--muted));
    font-size: 22px;
    cursor: pointer;
    padding: 0 6px;
    line-height: 1;
    border-radius: 6px;
    transition: color 0.12s, background 0.12s;
  }
  .sc-x:hover { color: rgb(var(--bright)); background: rgba(255,255,255,0.06); }
  body.light .sc-x:hover { background: rgba(0,0,0,0.04); }

  .sc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    padding: 16px;
  }
  @media (max-width: 640px) { .sc-grid { grid-template-columns: 1fr; } }

  .sc-opt {
    text-align: left;
    background: rgb(var(--surface));
    border: 1px solid var(--border-2);
    border-radius: 14px;
    padding: 20px;
    cursor: pointer;
    transition: all .15s;
    color: inherit;
    font-family: inherit;
    display: flex;
    flex-direction: column;
    gap: 10px;
    position: relative;
    overflow: hidden;
  }
  body.light .sc-opt { background: rgb(var(--card)); }
  .sc-opt:hover {
    transform: translateY(-2px);
    border-color: rgba(232, 181, 74, 0.30);
    box-shadow: 0 12px 32px rgba(0,0,0,0.18);
  }
  body.light .sc-opt:hover {
    border-color: rgba(40, 30, 20, 0.14);
    box-shadow: var(--shadow-lg);
  }

  .sc-opt::before {
    content: '';
    position: absolute;
    top: 0; right: 0; bottom: 0; left: 0;
    background: radial-gradient(circle at 100% 0%, var(--accent-glow), transparent 70%);
    opacity: 0.5;
    pointer-events: none;
  }
  .sc-opt-super::before {
    background: radial-gradient(circle at 100% 0%, rgba(167, 139, 250, 0.12), transparent 70%);
  }

  .sc-opt-top { display: flex; align-items: center; justify-content: space-between; position: relative; }
  .sc-opt-glyph {
    width: 36px; height: 36px;
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px;
  }
  .sc-opt-glyph-scan { background: rgba(110, 231, 183, 0.14); }
  .sc-opt-glyph-super { background: rgba(167, 139, 250, 0.14); }

  .sc-opt-badge {
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 3px 8px;
    border-radius: 999px;
    background: rgba(110, 231, 183, 0.10);
    color: rgba(110, 231, 183, 0.85);
  }
  .sc-badge-super { background: rgba(167, 139, 250, 0.10); color: rgba(167, 139, 250, 0.85); }
  body.light .sc-opt-badge { background: rgba(5, 150, 105, 0.08); color: #047857; }
  body.light .sc-badge-super { background: rgba(124, 58, 237, 0.08); color: #6d28d9; }

  .sc-opt-h {
    font-family: var(--serif);
    font-size: 18px;
    font-weight: 600;
    color: rgb(var(--bright));
    letter-spacing: -0.015em;
    position: relative;
  }
  .sc-opt-d {
    font-size: 12.5px;
    color: var(--bright-2);
    line-height: 1.5;
    position: relative;
    text-wrap: pretty;
  }
  .sc-opt-foot {
    display: flex;
    gap: 12px;
    margin-top: 4px;
    position: relative;
  }
  .sc-opt-stat {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--muted-2);
    padding: 3px 7px;
    border-radius: 5px;
    background: rgba(255,255,255,0.04);
  }
  body.light .sc-opt-stat { background: rgba(0,0,0,0.03); }

  .sc-opt-cta {
    margin-top: 4px;
    font-size: 12px;
    font-weight: 700;
    color: rgb(var(--accent));
    position: relative;
  }
  .sc-opt-super .sc-opt-cta { color: rgba(167, 139, 250, 0.95); }
  body.light .sc-opt-super .sc-opt-cta { color: #6d28d9; }

  .sc-foot {
    padding: 10px 22px 14px;
    font-size: 11px;
    color: var(--muted-2);
    border-top: 1px solid var(--border-2);
  }

  /* ═══════════════════════════════════════════════════════════════
     OVERLINE / SECTION HEADERS — per FIX_MANUAL Section 3g
     ═══════════════════════════════════════════════════════════════ */
  .text-overline {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--muted));
  }
}
