@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  :root {
    --ink: #221e1a;
    --ink-2: #1c1815;
    --surface: #2e2a25;
    --card: #36322c;
    --card-hi: #3d3830;
    --border: #4a443c;
    --border-2: rgba(245, 240, 232, 0.09);

    --bright: #faf6ef;
    --bright-2: rgba(250, 246, 239, 0.72);
    --bright-3: rgba(250, 246, 239, 0.50);
    --muted: #b8aea0;
    --muted-2: rgba(184, 174, 160, 0.66);

    --accent: #e6c79a;
    --accent-2: #f0d9b6;
    --accent-glow: rgba(230, 199, 154, 0.14);

    --bo: #93dafd;
    --boro: #d3c5fe;
    --sm: #86efc8;
    --amber: #fcc94d;
    --rose: #fb8a99;

    --sans: 'Geist', system-ui, -apple-system, 'Segoe UI', sans-serif;
    --serif: 'Fraunces', Georgia, serif;
    --mono: 'JetBrains Mono', ui-monospace, monospace;
  }

  * {
    -webkit-tap-highlight-color: transparent;
  }
  html {
    font-family: var(--sans);
  }
  body {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    background: var(--ink);
    color: var(--bright);
  }
  ::-webkit-scrollbar {
    width: 4px;
  }
  ::-webkit-scrollbar-track {
    background: transparent;
  }
  ::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 2px;
  }
}

@layer components {
  .glass-card {
    @apply bg-card/80 backdrop-blur-md border border-border/50 rounded-2xl;
  }
  .glow-accent {
    box-shadow: 0 0 20px var(--accent-glow), 0 0 60px rgba(230, 199, 154, 0.05);
  }
  .input-base {
    @apply w-full bg-surface border border-border/60 rounded-xl px-4 py-3 text-bright placeholder-muted/50 focus:outline-none focus:border-accent/50 focus:ring-1 focus:ring-accent/20 transition-all;
  }
  .btn-primary {
    @apply bg-accent text-ink font-bold px-6 py-3 rounded-xl active:scale-[0.97] transition-all;
  }
  .btn-ghost {
    @apply text-muted hover:text-bright px-4 py-2 rounded-lg transition-colors;
  }
  .tag {
    @apply text-xs font-mono px-2 py-1 rounded-md bg-accent-glow text-accent border border-accent/20;
  }
  .fade-in {
    animation: fadeIn 0.18s ease-out;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .slide-up {
    animation: slideUp 0.22s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(100%); }
    to { opacity: 1; transform: translateY(0); }
  }
}
